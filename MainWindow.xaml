<Window
    x:Class="Banking_app.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Wombat Bank - User"
    Width="900"
    Height="520"
    Icon="/Wombat_Bank.ico"
    Loaded="MainWindow_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <DockPanel Grid.Column="0" Background="#FFEFEFEF">

            <!--  Logout unten  -->
            <Button
                Height="34"
                Margin="10"
                Click="Logout_Click"
                Content="Logout"
                DockPanel.Dock="Bottom" />

            <StackPanel Margin="10">
                <TextBlock
                    Margin="0,0,0,10"
                    FontWeight="SemiBold"
                    Text="Menü" />

                <ListBox x:Name="MenuList" SelectionChanged="MenuList_SelectionChanged">
                    <ListBoxItem Content="Start" />
                    <ListBoxItem Content="Konto" />
                    <ListBoxItem Content="Transaktionen" />
                    <ListBoxItem Content="Karten" />
                    <ListBoxItem Content="Einstellungen" />
                </ListBox>
            </StackPanel>
        </DockPanel>

        <!--  Content  -->
        <Frame
            x:Name="MainFrame"
            Grid.Column="1"
            NavigationUIVisibility="Hidden" />
    </Grid>
</Window>