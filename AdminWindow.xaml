<Window
    x:Class="Banking_app.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Wombat Bank - Admin"
    Width="1000"
    Height="600"
    MinWidth="1000"
    MinHeight="600"
    Icon="/Wombat_Bank.ico"
    Loaded="AdminWindow_Loaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <StackPanel
            Grid.Column="0"
            Margin="12"
            Background="#FF2B2B2B">
            <TextBlock
                Margin="8,6,8,14"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Text="Admin Menü" />

            <Button
                Height="40"
                Margin="0,0,0,10"
                Click="Users_Click"
                Content="Benutzerverwaltung" />

            <Separator Margin="0,10" />

            <Button
                Height="40"
                Click="Logout_Click"
                Content="Logout" />
        </StackPanel>

        <Frame
            x:Name="AdminFrame"
            Grid.Column="1"
            Margin="12"
            NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
