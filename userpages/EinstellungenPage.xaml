<Page
    x:Class="Banking_app.userpages.EinstellungenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Einstellungen">

    <Grid Background="#FFF6F7FB">
        <Border
            Width="420"
            Padding="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            BorderBrush="#FFE5E7EB"
            BorderThickness="1"
            CornerRadius="14">

            <StackPanel>

                <!--  Titel  -->
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="#FF111827"
                    Text="Passwort ändern" />

                <TextBlock
                    Margin="0,6,0,20"
                    FontSize="12"
                    Foreground="#FF6B7280"
                    Text="Bitte gib dein aktuelles Passwort ein und wähle ein neues."
                    TextAlignment="Center" />

                <!--  Aktuelles Passwort  -->
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="#FF6B7280"
                    Text="Aktuelles Passwort" />

                <PasswordBox
                    x:Name="TxtOldPassword"
                    Height="36"
                    Margin="0,0,0,16"
                    Padding="10"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1" />

                <!--  Neues Passwort  -->
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="#FF6B7280"
                    Text="Neues Passwort" />

                <PasswordBox
                    x:Name="TxtNewPassword"
                    Height="36"
                    Margin="0,0,0,16"
                    Padding="10"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1" />

                <!--  Wiederholen  -->
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="#FF6B7280"
                    Text="Neues Passwort wiederholen" />

                <PasswordBox
                    x:Name="TxtRepeatPassword"
                    Height="36"
                    Margin="0,0,0,12"
                    Padding="10"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1" />

                <!--  Fehlermeldung  -->
                <TextBlock
                    x:Name="TxtError"
                    Margin="0,0,0,12"
                    FontSize="12"
                    Foreground="#DC2626"
                    TextAlignment="Center"
                    Visibility="Collapsed" />

                <!--  Button  -->
                <Button
                    Height="40"
                    Background="#FF2563EB"
                    BorderThickness="0"
                    Click="Button_Click"
                    Content="Passwort ändern"
                    Cursor="Hand"
                    Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>