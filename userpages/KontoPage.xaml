<Page
    x:Class="Banking_app.userpages.KontoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Konto">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Links: Konto + Überweisung  -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Konto" />

                <!--  Konto auswählen  -->
                <TextBlock Margin="0,0,0,4" Text="Konto auswählen" />
                <ComboBox
                    x:Name="CbAccounts"
                    Height="32"
                    SelectionChanged="CbAccounts_SelectionChanged" />

                <!--  Kontostand  -->
                <Border
                    Margin="0,12,0,12"
                    Padding="10"
                    BorderBrush="#DDD"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Kontostand" />
                        <TextBlock
                            x:Name="TxtBalance"
                            Margin="0,6,0,0"
                            FontSize="22"
                            Text="—" />
                        <TextBlock
                            x:Name="TxtIban"
                            Margin="0,6,0,0"
                            Opacity="0.8"
                            Text="IBAN: —" />
                        <TextBlock
                            x:Name="TxtAccStatus"
                            Margin="0,2,0,0"
                            Opacity="0.8"
                            Text="Status: —" />
                    </StackPanel>
                </Border>

                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Überweisung" />

                <TextBlock Margin="0,0,0,4" Text="Empfänger Name" />
                <TextBox x:Name="TbToName" Height="30" />

                <TextBlock Margin="0,10,0,4" Text="Empfänger IBAN" />
                <TextBox x:Name="TbToIban" Height="30" />

                <TextBlock Margin="0,10,0,4" Text="Betrag" />
                <TextBox x:Name="TbAmount" Height="30" />

                <TextBlock Margin="0,10,0,4" Text="Verwendungszweck (optional)" />
                <TextBox x:Name="TbPurpose" Height="30" />

                <Button
                    x:Name="BtnSend"
                    Height="40"
                    Margin="0,12,0,0"
                    Click="Send_Click"
                    Content="Überweisung ausführen" />

                <Button
                    Height="36"
                    Margin="0,10,0,0"
                    Click="Reload_Click"
                    Content="Neu laden" />
            </StackPanel>
        </ScrollViewer>

        <!--  Rechts: letzte Transaktionen  -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Margin="0,0,0,8"
                FontSize="16"
                FontWeight="SemiBold"
                Text="Letzte Transaktionen" />

            <DataGrid
                x:Name="DgTransfers"
                Grid.Row="1"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="160"
                        Binding="{Binding created_at}"
                        Header="Zeit" />
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding direction}"
                        Header="Typ" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding partner}"
                        Header="Partner" />
                    <DataGridTextColumn
                        Width="220"
                        Binding="{Binding partner_iban}"
                        Header="IBAN" />

                    <DataGridTextColumn Width="110" Header="Betrag">
                        <DataGridTextColumn.Binding>
                            <Binding Path="amount_signed" StringFormat="{}{0:+0.00;-0.00}" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding direction}" Value="IN">
                                        <Setter Property="Foreground" Value="Green" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding direction}" Value="OUT">
                                        <Setter Property="Foreground" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding status}"
                        Header="Status" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>